{
  "name": "@nordenwinds/web",
  "description": "Frontend of officialsite",
  "author": "Norden Wind Ensemble",
  "license": "MIT",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "typegen:contentful": "cf-content-types-generator --typeguard --spaceId $CONTENTFUL_SPACE_ID --token $CONTENTFUL_MANAGEMENT_TOKEN --environment $CONTENTFUL_ENV --out src/types/contentful",
    "typegen:api": "openapi-typescript ${API_BASE_URL:-http://localhost:8080/v1}/openapi.json -o src/types/api/v1.d.ts",
    "typegen": "pnpm typegen:contentful && pnpm typegen:api",
    "check": "astro check && tsc --noEmit",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/check": "0.9.8",
    "@astrojs/mdx": "4.3.14",
    "@astrojs/rss": "4.0.18",
    "@astrojs/sitemap": "3.7.2",
    "@astrojs/ts-plugin": "1.10.7",
    "@contentful/rich-text-html-renderer": "^17.0.0",
    "@contentful/rich-text-plain-text-renderer": "^17.0.0",
    "@contentful/rich-text-types": "^17.0.0",
    "@fontsource/noto-sans-jp": "^5.1.1",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.0.3",
    "astro": "5.18.1",
    "contentful": "^11.4.4",
    "openapi-fetch": "^0.17.0",
    "tailwindcss": "^4.0.3"
  },
  "devDependencies": {
    "cf-content-types-generator": "^3.0.0",
    "openapi-typescript": "^7.5.2"
  }
}
